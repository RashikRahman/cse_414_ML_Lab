from sklearn.cluster import DBSCAN
import pandas as pd

df = pd.read_csv('./pedestrian-crashes-chapel-hill-region-original.csv')


mdf = df[['latitude', 'longitude']]

model = DBSCAN().fit(mdf)
model.labels_


mdf['label']=model.labels_
mdf.head()


mdf.label.unique()


# Modeling

mdf = df[['latitude', 'longitude']]
model = DBSCAN(eps=0.05, min_samples=8, metric='manhattan').fit(mdf)
mdf['label']=model.labels_
mdf.label.unique()


mdf[mdf.label==-1].shape #5% Outliers 


mdf.shape


mdf = mdf[~(mdf.label==-1)]
mdf.shape


import folium

world_map = folium.Map(location=[34.63932, -77.9439],zoom_start=7)
incidents = folium.map.FeatureGroup()

colormap = {0:"#F19191",  1:"#F1AB91",  2:"#F1C491",  3:"#F1D491",  4:"#F1EA91",  5:"#DEF191",  6:"#C2F191",  7:"#A5F191",  8:"#91F199", 40:"#91F1B1",  9:"#91F1D3", 10:"#91F1F1", 11:"#91D4F1", 12:"#91BEF1", 
            13:"#91A5F1", 14:"#BD91F1", 15:"#D991F1", 16:"#F191E9", 17:"#F191BB", 18:"#FF4F4F", 28:"#FF924F", 19:"#FFC24F", 20:"#FFEA4F", 21:"#ECFF4F", 22:"#AFFF4F", 23:"#8CFF4F", 24:"#5CFF4F", 25:"#4FFFAC", 
            26:"#4FFFDC", 27:"#4FFFF7", 29:"#4FDCFF", 30:"#4FAFFF", 31:"#4F97FF", 32:"#4F6FFF", 33:"#5F4FFF", 34:"#9C4FFF", 35:"#E24FFF", 36:"#FF4FEF", 37:"#FF4F9A", 38:"#FF0000", 44:"#FF8300", 39:"#FFC100", 
            41:"#FFF000", 42:"#E0FF00", 43:"#AEFF00", 45:"#8BFF00", 46:"#59FF00", 47:"#00FF23", 48:"#00FFA2", 49:"#00FFD1",  58:"#00F3FF", 50:"#00BDFF", 61:"#00A2FF", 51:"#0087FF", 52:"#0070FF", 
            56:"#003EFF", 54:"#8300FF", 53:"#C100FF", 55:"#FF00FF", 60:"#FF00AA", 57:"#6A5864", 59:"#898D2F" }

for lat, lng, label, in zip(mdf.latitude, mdf.longitude, mdf.label):
    if label>59:
                color="#000000"
    else:
        color=colormap[label],
    
    incidents.add_child(
        folium.CircleMarker(
            [lat, lng],
            radius=5, # define how big you want the circle markers to be
            color=color,
            fill=True,
            fill_color='white',
            fill_opacity=0.6,
            popup = (lat, lng, label),
        )
    )

# add incidents to map
world_map.add_child(incidents)

world_map


