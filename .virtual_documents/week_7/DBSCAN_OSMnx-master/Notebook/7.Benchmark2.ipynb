from sklearn.cluster import DBSCAN
import pandas as pd
import numpy as np


df = pd.read_csv('../Data/countries_csv.csv', encoding='latin-1')
df.dropna(inplace=True)
df


mdf = df[['latitude','longitude']]


mdf.isnull().sum()


mdf.columns


model = DBSCAN(eps=(100000/111111.0) , min_samples=4, metric='haversine').fit(mdf)
mdf['label']=model.labels_
mdf.label.unique()



import folium

world_map = folium.Map(location=[35.844117, -80.261648],zoom_start=12)
incidents = folium.map.FeatureGroup()

colormap = {0:"#F19191",  1:"#00FFD1",  2:"#F1C491",  3:"#F1D491",  4:"#F1EA91" }


for lat, lng,label, in zip(mdf.latitude, mdf.longitude, mdf.label):
    if label==-1:
                color="#000000"
    else:
        color=colormap[label],
        
    
    incidents.add_child(
        folium.CircleMarker(
            [lat, lng],
            radius=5, # define how big you want the circle markers to be
            color=color,
            fill=True,
            fill_color='white',
            fill_opacity=0.6,
            popup = (lat, lng,label),
        )
    )

# add incidents to map
world_map.add_child(incidents)
world_map.save('../Visualization/Python_world_map.html')
world_map


