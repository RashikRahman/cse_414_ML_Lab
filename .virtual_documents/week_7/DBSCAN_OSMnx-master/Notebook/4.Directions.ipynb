mf = mdf.copy()
mf.drop('label', axis=1,inplace=True)

import numpy as np 
import matplotlib.pyplot as plt


def k_distances2(x, k):
    dim0 = x.shape[0]
    dim1 = x.shape[1]
    p=-2*x.dot(x.T)+np.sum(x**2, axis=1).T+ np.repeat(np.sum(x**2, axis=1),dim0,axis=0).reshape(dim0,dim0)
    p = np.sqrt(p)
    p.sort(axis=1)
    p=p[:,:k]
    pm= p.flatten()
    pm= np.sort(pm)
    return p, pm

m, m2= k_distances2(mf.values, 2)
plt.plot(m2)
plt.ylabel("k-distances")
plt.xlabel("Min-pts")
plt.grid(True)
plt.show()



