def draw_geo(st,en,f):
    
    start = df.loc[st].values[1],df.loc[st].values[2]
    srt = str(start[0])+','+str(start[1])

    end = df.loc[en].values[1],df.loc[en].values[2]
    ed = str(end[0])+','+str(end[1])


    endpoint = 'https://maps.googleapis.com/maps/api/directions/json?'
    api_key = 'AIzaSyCKgvBmwCTenYMbkcyT4QI5xzgAv7qODAg'
    #Asks the user to input Where they are and where they want to go.
    origin = srt
    destination = ed
    #Building the URL for the request
    nav_request = 'origin='+origin+'&destination='+destination+'&key='+str(api_key)
    request = endpoint + nav_request
    #Sends the request and reads the response.
    response = urllib.request.urlopen(request).read()
    #Loads response as JSON
    directions = json.loads(response)

    lat = []
    long = []

    lat.append(start[0])
    long.append(start[1])



    siz = len(directions['routes'][0]['legs'][0]['steps'])
    for i in range(siz):
    #     print(directions['routes'][0]['legs'][0]['steps'][i]['end_location'])
        lat.append(directions['routes'][0]['legs'][0]['steps'][i]['end_location']['lat'])
        long.append(directions['routes'][0]['legs'][0]['steps'][i]['end_location']['lng'])

    lat.append(end[0])
    long.append(end[1])



    gmap = gmplot.GoogleMapPlotter(start[0],start[1],15)
    gmap.scatter(lat,long,'#A24444',size=15,marker=False)
    gmap.plot(lat,long,'blue',edge_width=2.5)
    gmap.draw('../Visualization/map'+str(f)+'.html')
    
    return directions


