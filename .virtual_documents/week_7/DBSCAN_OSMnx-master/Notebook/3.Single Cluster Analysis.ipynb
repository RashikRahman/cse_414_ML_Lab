


import pandas as pd
df2 = pd.read_csv('../Data/SingleCluster.csv')
df2.head()


df2.shape


import folium

# Initial visualization

world_map = folium.Map(location=[35.37344718, -80.78484335],zoom_start=9)
incidents = folium.map.FeatureGroup()

for lat, lng, injury, in zip(df2.latitude, df2.longitude, df2.drvrinjury):
    
    incidents.add_child(
        folium.CircleMarker(
            [lat, lng],
            radius=5, # define how big you want the circle markers to be
            color="black",
            fill=True,
            fill_color='white',
            fill_opacity=0.6,
            popup = (lat, lng, injury),
        )
    )

# add incidents to map
world_map.add_child(incidents)

world_map


